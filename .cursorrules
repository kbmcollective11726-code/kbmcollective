## Common Patterns

### Fetching data with loading state:
```typescript
const [data, setData] = useState<Post[]>([]);
const [loading, setLoading] = useState(true);

useEffect(() => {
  fetchData();
}, []);

const fetchData = async () => {
  try {
    setLoading(true);
    const { data, error } = await supabase
      .from('posts')
      .select('*, user:users(id, full_name, avatar_url)')
      .eq('event_id', currentEventId)
      .eq('is_deleted', false)
      .order('created_at', { ascending: false })
      .limit(20);
    if (error) throw error;
    setData(data);
  } catch (err) {
    Toast.show({ type: 'error', text1: 'Failed to load posts' });
  } finally {
    setLoading(false);
  }
};
```

### Real-time subscription:
```typescript
useEffect(() => {
  const channel = supabase
    .channel('posts-feed')
    .on('postgres_changes', 
      { event: 'INSERT', schema: 'public', table: 'posts', filter: `event_id=eq.${eventId}` },
      (payload) => {
        setData(prev => [payload.new as Post, ...prev]);
      }
    )
    .subscribe();

  return () => { supabase.removeChannel(channel); };
}, [eventId]);
```

### Points awarding:
```typescript
const awardPoints = async (userId: string, eventId: string, action: string, referenceId?: string) => {
  const { data: rule } = await supabase
    .from('point_rules')
    .select('points_value, max_per_day')
    .eq('event_id', eventId)
    .eq('action', action)
    .single();
  
  if (!rule) return;

  // Check daily limit
  if (rule.max_per_day) {
    const today = new Date().toISOString().split('T')[0];
    const { count } = await supabase
      .from('point_log')
      .select('*', { count: 'exact', head: true })
      .eq('user_id', userId)
      .eq('event_id', eventId)
      .eq('action', action)
      .gte('created_at', today);
    
    if ((count ?? 0) >= rule.max_per_day) return;
  }

  await supabase.from('point_log').insert({
    user_id: userId,
    event_id: eventId,
    action,
    points: rule.points_value,
    reference_id: referenceId,
  });
};
```

## DO NOT
- Do not use class components
- Do not use `any` type — always type properly
- Do not store sensitive keys in the app code (use environment variables)
- Do not skip error handling
- Do not use inline styles for complex styling — use StyleSheet
- Do not fetch all records without pagination
- Do not skip loading states — always show a skeleton or spinner
