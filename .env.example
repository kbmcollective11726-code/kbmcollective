# Supabase — copy to .env and fill in. Never commit .env.
# Get these from: Supabase Dashboard → Your Project → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Optional: run setup SQL from CLI (scripts/run-supabase-sql.mjs)
# Get from: Dashboard → Project Settings → Database → Connection string → URI
# DATABASE_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres

# For Expo Go: after adding/editing .env, run: npx expo start --clear (see EXPO-GO-SETUP.md)

# Live wall URL (opened from hamburger menu). Default: http://localhost:3000
# EXPO_PUBLIC_LIVE_WALL_URL=http://localhost:3000

# Android: set to "true" to try posting directly to R2 (like iOS). Default: unset = Android uses Supabase Storage only.
# EXPO_PUBLIC_ANDROID_USE_R2=true
