# Supabase — copy to .env and fill in. Never commit .env.
# Get these from: Supabase Dashboard → Your Project → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Optional: run setup SQL from CLI (npm run supabase:verify, run-supabase-sql.mjs)
# Get from: Dashboard → Project Settings → Database → Connection string → URI
# Copy the FULL string from the dashboard (do not guess host/port).
# Pooler: user MUST be postgres.<project-ref> (e.g. postgres.noydhokbswedvltjyenr), NOT plain "postgres".
# Password = database password (reset on that page if needed), NOT the anon API key.
# "Tenant or user not found" = wrong user/password/host — paste fresh URI; try Session mode or Direct connection.
# DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:[YOUR-PASSWORD]@aws-0-REGION.pooler.supabase.com:5432/postgres

# For Expo Go: after adding/editing .env, run: npx expo start --clear (see EXPO-GO-SETUP.md)

# Live wall URL (opened from hamburger menu → Live wall). REQUIRED for real devices / TestFlight:
# use your deployed Next.js app (https://…), NOT localhost — phones can't reach your PC.
# Local dev: EXPO_PUBLIC_LIVE_WALL_URL=http://localhost:3000 (run: cd live-wall && npm run dev)
# Production: add the same variable to eas.json → build.production.env (or Expo dashboard → Environment variables).
# EXPO_PUBLIC_LIVE_WALL_URL=https://your-live-wall.vercel.app

# Password reset email → opens HTTPS page → opens app (avoids localhost in the browser).
# 1) Deploy admin-setup to Vercel (includes public/auth-recovery.html).
# 2) Set this to: https://YOUR_ADMIN_VERCEL_DOMAIN/auth-recovery.html
# 3) Supabase Dashboard → Authentication → URL Configuration → Redirect URLs → add that exact URL.
# 4) Site URL: use the same https URL (or your main https site), NOT http://localhost.
# EXPO_PUBLIC_PASSWORD_RESET_WEB_URL=https://admin-setup-omega.vercel.app/auth-recovery.html

# Android: set to "true" to try posting directly to R2 (like iOS). Default: unset = Android uses Supabase Storage only.
# EXPO_PUBLIC_ANDROID_USE_R2=true
