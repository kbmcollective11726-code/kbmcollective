# Copy this file to .env.local and fill in with the SAME values as the main app .env
# (Main app uses EXPO_PUBLIC_SUPABASE_*; Next.js needs NEXT_PUBLIC_SUPABASE_*)
# Get these from: Supabase Dashboard → Your Project → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
